# Ghostty Configuration - GreymHatter DFIR Distribution
# Replaces Alacritty with equivalent settings (Nord theme, Hack Nerd Font)

# Font
font-family = Hack Nerd Font
font-size = 12

# Shell
command = /usr/bin/fish --login

# Window
window-padding-x = 5
window-padding-y = 5
window-width = 120
window-height = 40

# Appearance
background-opacity = 0.9
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true
scrollback-limit = 100000

# Nord color theme
background = 2e3440
foreground = d8dee9

# Normal colors
palette = 0=#3b4252
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#81a1c1
palette = 5=#b48ead
palette = 6=#88c0d0
palette = 7=#e5e9f0

# Bright colors
palette = 8=#4c566a
palette = 9=#bf616a
palette = 10=#a3be8c
palette = 11=#ebcb8b
palette = 12=#81a1c1
palette = 13=#b48ead
palette = 14=#8fbcbb
palette = 15=#eceff4

# Clipboard
copy-on-select = clipboard
