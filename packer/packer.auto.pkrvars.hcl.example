# Copy this file to greymhatter.auto.pkrvars.hcl and fill in your values.
# DO NOT commit *.auto.pkrvars.hcl — it contains credentials.

# --- Proxmox Connection ---
proxmox_url      = "https://192.168.1.100:8006/api2/json"
proxmox_node     = "pve"
proxmox_username = "root@pam"
proxmox_password = "your-proxmox-password"

# Or use API token instead of password:
# proxmox_username = "packer@pve!packer-token"
# proxmox_token    = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# --- Proxmox Storage ---
proxmox_storage_pool = "local-lvm"
proxmox_iso_storage  = "local"
proxmox_bridge       = "vmbr0"

# --- VM Specs ---
vm_cpus      = 4
vm_memory    = 8192
vm_disk_size = "80G"

# --- Fedora ISO (update for new releases) ---
iso_url_amd64      = "https://download.fedoraproject.org/pub/fedora/linux/releases/42/Server/x86_64/iso/Fedora-Server-netinst-x86_64-42-1.1.iso"
iso_checksum_amd64 = "none"
